NEXT_PUBLIC_MAPBOX_TOKEN=<your_token>
GOOGLE_PLACES_API_KEY=<your_key>

# Sentry error tracking (free tier — https://sentry.io)
# Create a project at sentry.io, copy the DSN from Settings > Projects > <project> > Client Keys
# SENTRY_DSN is server-side only; NEXT_PUBLIC_SENTRY_DSN is the same value, exposed to the client bundle
# Leave both empty to run without Sentry (app works fine without it)
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
